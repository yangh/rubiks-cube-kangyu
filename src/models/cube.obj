# Simple cube with normals
# Vertices
v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

# Normals
vn 0.0  0.0 -1.0
vn 0.0  0.0  1.0
vn 0.0 -1.0  0.0
vn 0.0  1.0  0.0
vn 1.0  0.0  0.0
vn -1.0  0.0  0.0

# Faces (front)
f 2//1 3//1 4//1 1//1
# Back
f 8//2 7//2 6//2 5//2
# Bottom
f 5//3 6//3 2//3 1//3
# Top
f 3//4 7//4 8//4 4//4
# Right
f 6//5 7//5 8//8 5//8
# Left
f 1//6 4//6 8//8 5//8
